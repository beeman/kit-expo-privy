{
  "name": "kit-expo-privy",
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "build": "tsc --noEmit && npm run android:build",
    "ci": "tsc --noEmit && npm run lint:check && npm run format:check && npm run android:build",
    "dev": "expo start --clear --dev-client --reset-cache",
    "doctor": "npx -y expo-doctor@latest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ios": "expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "start": "expo start",
    "web": "expo start --web"
  },
  "displayName": "Uniwind Mobile Kit Expo example",
  "description": "A template for building a Solana mobile app with Expo, React Native, Solana Kit, and Uniwind.",
  "usecase": "Mobile",
  "keywords": [
    "expo",
    "mobile-wallet-adapter",
    "react-native",
    "solana-kit",
    "uniwind",
    "tailwind"
  ],
  "main": "./index.js",
  "version": "1.0.0",
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@privy-io/expo": "^0.65.5",
    "@privy-io/expo-native-extensions": "^0.0.11",
    "@solana/kit": "^6.1.0",
    "@wallet-ui/react-native-kit": "^4.0.1",
    "expo": "~55.0.23",
    "expo-apple-authentication": "~55.0.13",
    "expo-application": "~55.0.15",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "^55.0.18",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.14",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.16",
    "fast-text-encoding": "^1.0.6",
    "react": "~19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-passkeys": "^0.4.1",
    "react-native-quick-crypto": "^1.0.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0",
    "tailwindcss": "~4.1.16",
    "uniwind": "~1.0.0",
    "viem": "2.47.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
